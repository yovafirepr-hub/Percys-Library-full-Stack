# Postgres connection string (Supabase or local). The Prisma schema
# uses `postgresql`, so this MUST be a postgres:// URL.
#
# For local development, the bundled docker-compose.yml ships a Postgres
# matching the URL below — just `docker compose up -d` from the repo
# root and you're good to go. For Supabase, copy the value from Project
# Settings → Database → Connection string. Recommended modes:
#   - "Session pooler" (port 5432, host aws-0-<region>.pooler.supabase.com,
#     user postgres.<project-ref>) — works from IPv4-only networks and
#     supports Prisma migrations.
#   - "Direct" (port 5432, host db.<project-ref>.supabase.co) — only
#     works if your network has IPv6 connectivity OR you have the IPv4
#     add-on enabled. Free-tier projects auto-pause after ~1 week of
#     inactivity; reactivate from the dashboard before connecting.
#
# Examples:
#   Local docker:     postgresql://postgres:postgres@localhost:5432/percys
#   Supabase pooler:  postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
#   Supabase direct:  postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/percys"

# Node mode: development | test | production. Affects logging defaults
# and crash semantics (production hard-exits on uncaughtException).
NODE_ENV="development"

# Path scanned for comics (CBZ / CBR / PDF / folders of images).
# Uploaded files land in <LIBRARY_PATH>/_uploads/.
LIBRARY_PATH="./data/library"

# Cache directory (covers + page thumbs + rasterized PDF pages)
CACHE_DIR="./cache"

# Server port
PORT=4000

# Logging: debug | info | warn | error | silent
LOG_LEVEL="info"

# CORS allow-list. "*" (default) accepts every origin; set to a
# comma-separated list (e.g. "https://app.example.com") to lock things
# down in production.
CORS_ORIGINS="*"

# Rate limiting (per IP, per window). Reads (GET) skip the write limiter
# entirely; uploads have their own dedicated quota.
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX=600
RATE_LIMIT_UPLOAD_MAX=30

# JSON body cap; uploads are handled by multer separately and aren't
# bounded by this value.
JSON_BODY_LIMIT="10mb"

# Number of pages kept in the in-process LRU page cache. Disk cache is
# unbounded by count and self-prunes when the on-disk size exceeds
# 1 GiB (pages) / 256 MiB (thumbs).
PAGE_MEMORY_CACHE_ITEMS=60
