# Postgres connection string (Supabase or local). The Prisma schema
# uses `postgresql`, so this MUST be a postgres:// URL.
#
# For Supabase, copy the value from Project Settings → Database →
# Connection string. Recommended modes:
#   - "Session pooler" (port 5432, host aws-0-<region>.pooler.supabase.com,
#     user postgres.<project-ref>) — works from IPv4-only networks and
#     supports Prisma migrations.
#   - "Direct" (port 5432, host db.<project-ref>.supabase.co) — only
#     works if your network has IPv6 connectivity OR you have the IPv4
#     add-on enabled. Free-tier projects auto-pause after ~1 week of
#     inactivity; reactivate from the dashboard before connecting.
#
# Examples:
#   Supabase pooler:  postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
#   Supabase direct:  postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
#   Local Postgres:   postgresql://postgres:postgres@localhost:5432/percys
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/percys"

# Path scanned for comics (CBZ / CBR / PDF / folders of images).
# Uploaded files land in <LIBRARY_PATH>/_uploads/.
LIBRARY_PATH="./data/library"

# Cache directory (covers + page thumbs + rasterized PDF pages)
CACHE_DIR="./cache"

# Server
PORT=4000
