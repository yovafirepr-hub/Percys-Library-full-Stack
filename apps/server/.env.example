# Postgres connection string (Supabase or local). The Prisma schema
# uses `postgresql`, so this MUST be a postgres:// URL. For Supabase,
# copy the value from Project Settings → Database → Connection string
# (URI). Direct connection (port 5432) is fine for the long-running
# Node server; you don't need the pooler.
#
# Example (Supabase): postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/percys"

# Path scanned for comics (CBZ / CBR / PDF / folders of images).
# Uploaded files land in <LIBRARY_PATH>/_uploads/.
LIBRARY_PATH="./data/library"

# Cache directory (covers + page thumbs + rasterized PDF pages)
CACHE_DIR="./cache"

# Server
PORT=4000
