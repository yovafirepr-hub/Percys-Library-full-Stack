# Dependencies — these are regenerated by `npm install` and should never be tracked.
node_modules/
**/node_modules/

# Build output / bundlers / caches
apps/web/dist/
apps/server/dist/
**/dist/
**/.vite/
**/.turbo/
**/.cache/
**/.next/
**/coverage/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS noise
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo
*~

# Local environment files (real secrets stay out of git; use .env.example as template)
.env
.env.local
.env.*.local
apps/server/.env
apps/web/.env

# Local SQLite databases (Prisma). Run `npm --workspace apps/server run prisma:push`
# to recreate your dev.db locally.
apps/server/prisma/*.db
apps/server/prisma/*.db-journal
**/prisma/*.db
**/prisma/*.db-journal
apps/server/dev.db
apps/server/prisma/prisma/

# Supabase CLI local state.
supabase/.temp/

# User-imported comics and derived caches. These belong to the running
# user, not the repo, and contain test data we never want shipped.
apps/server/data/
apps/server/cache/

# Test scratch files (test plans / reports / fixtures generated locally).
test-plan.md
test-report.md
